# ==================================================
# e-Base Runtime Environment
# ==================================================
# APP_ENV:
# - production
# - development
APP_ENV=production

# ==================================================
# MySQL Main Application Database
# Digunakan untuk login sistem, config, audit, cache, dll.
# ==================================================
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_NAME=ebasedb
DB_MYSQL_CHARSET=utf8mb4
DB_MYSQL_USER=your_mysql_user
DB_MYSQL_PASS=your_mysql_password

# ==================================================
# Sybase Staff - Production
# Digunakan untuk flow staf sebenar dalam mode production.
# ==================================================
SYBASE_STAFF_PROD_HOST=172.16.2.14
SYBASE_STAFF_PROD_PORT=5004
SYBASE_STAFF_PROD_DB=ehrmdb
SYBASE_STAFF_PROD_USER=your_staff_prod_user
SYBASE_STAFF_PROD_PASS=your_staff_prod_password
SYBASE_STAFF_PROD_DSN=dsn_sybase_ehrmdb

# ==================================================
# Sybase Staff - Development
# Digunakan untuk flow staf dalam mode development/testing.
# ==================================================
SYBASE_STAFF_DEV_HOST=172.16.2.8
SYBASE_STAFF_DEV_PORT=7000
SYBASE_STAFF_DEV_DB=ehrmdb
SYBASE_STAFF_DEV_USER=your_staff_dev_user
SYBASE_STAFF_DEV_PASS=your_staff_dev_password
SYBASE_STAFF_DEV_DSN=dsn_sybase_ehrmdb_dev

# ==================================================
# Sybase Student - Production
# Digunakan untuk carian/akses data pelajar dalam mode production.
# ==================================================
SYBASE_STUDENT_PROD_HOST=172.16.2.14
SYBASE_STUDENT_PROD_PORT=5004
SYBASE_STUDENT_PROD_DB=asisdb
SYBASE_STUDENT_PROD_USER=your_student_prod_user
SYBASE_STUDENT_PROD_PASS=your_student_prod_password
SYBASE_STUDENT_PROD_DSN=dsn_sybase_student_prod

# ==================================================
# Sybase Student - Development
# Digunakan untuk carian/akses data pelajar dalam mode development/testing.
# ==================================================
SYBASE_STUDENT_DEV_HOST=172.16.2.8
SYBASE_STUDENT_DEV_PORT=7000
SYBASE_STUDENT_DEV_DB=asisdb
SYBASE_STUDENT_DEV_USER=your_student_dev_user
SYBASE_STUDENT_DEV_PASS=your_student_dev_password
SYBASE_STUDENT_DEV_DSN=dsn_sybase_student_dev
