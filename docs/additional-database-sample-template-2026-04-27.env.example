############################################################
# Mapping kepada UI registry
############################################################
#
# Dalam UI Additional Connections:
#
# Code:
#   dbx_mysql_reporting
#
# Name:
#   Reporting Database
#
# Type:
#   mysql
#
# Purpose:
#   reporting
#
# Driver Mode:
#   auto
#
# Env Row contoh MySQL production:
#   environment: production
#   os_family: any
#   driver: mysql
#   host: 127.0.0.1
#   port: 3306
#   database_name: reporting_db
#   username: report_user
#   password: change_me
#   charset: utf8mb4
#   is_active: 1
