# Additional Database Sample Templates
# Tarikh: 2026-04-27
#
# Nota:
# - Fail ini contoh rujukan sahaja.
# - Ia tidak digunakan secara automatik oleh runtime semasa.
# - Main runtime kekal menggunakan config utama sedia ada.
# - Additional connection sebenar untuk platform semasa disimpan melalui UI
#   dan registry table:
#   - tbl_m_db_connection
#   - tbl_m_db_connection_env
#
# Gunakan kandungan ini sebagai template semasa menyediakan rekod dalam UI
# atau jika anda mahu dokumen rujukan konfigurasi luar.

############################################################
# 1. MySQL Reporting
############################################################

DBX_MYSQL_REPORTING_CODE=dbx_mysql_reporting
DBX_MYSQL_REPORTING_NAME=Reporting Database
DBX_MYSQL_REPORTING_FAMILY=mysql
DBX_MYSQL_REPORTING_PURPOSE=reporting
DBX_MYSQL_REPORTING_DRIVER_MODE=auto

DBX_MYSQL_REPORTING_PROD_HOST=127.0.0.1
DBX_MYSQL_REPORTING_PROD_PORT=3306
DBX_MYSQL_REPORTING_PROD_NAME=reporting_db
DBX_MYSQL_REPORTING_PROD_USER=report_user
DBX_MYSQL_REPORTING_PROD_PASS=change_me
DBX_MYSQL_REPORTING_PROD_CHARSET=utf8mb4

DBX_MYSQL_REPORTING_DEV_HOST=127.0.0.1
DBX_MYSQL_REPORTING_DEV_PORT=3306
DBX_MYSQL_REPORTING_DEV_NAME=reporting_db_dev
DBX_MYSQL_REPORTING_DEV_USER=report_user_dev
DBX_MYSQL_REPORTING_DEV_PASS=change_me
DBX_MYSQL_REPORTING_DEV_CHARSET=utf8mb4

